# Frontend (Vite) — copy to .env.local for local dev, or set in Netlify UI
# Public anon key only (never the service role key)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Backend API (no trailing /api). Local: Vite proxies /api to this when set.
# Production: your Render web service URL, e.g. https://pharmazine-api.onrender.com
VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional: override Vite dev proxy target (defaults to VITE_API_BASE_URL or http://127.0.0.1:8000)
# VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:8000
