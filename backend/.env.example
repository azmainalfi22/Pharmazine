# PostgreSQL — Supabase: Project Settings → Database → Connection string (copy URI as-is)
# If YOUR_PASSWORD contains @ : / # ? or other reserved URI characters, encode them (e.g. @ → %40)
# or paste the string from Supabase — a bad string looks like host "3939@db....supabase.co" in errors.
#
# Direct (db.*.supabase.co:5432) is often IPv6-only. If Python/psycopg2 reports
# "could not translate host name" / "No such host" on Windows, use the
# Transaction pooler URI from the same page (port 6543; IPv4-friendly), not the direct host.
# Direct (IPv6-compatible; port 5432):
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.qghtxzutmtyqpotokrnv.supabase.co:5432/postgres?sslmode=require
# Transaction pooler (port 6543; IPv4-friendly). Copy the full URI from the dashboard — username is often
# postgres.PROJECT_REF (not plain postgres). Always append ?sslmode=require if not already in the string.
# Dashboard snippets may show [YOUR_PASSWORD] — brackets mean “replace with your password”, not literal characters.
# Pooler (port 6543, often better for serverless): copy from the same dashboard page (URI or "Transaction pooler").

# Supabase — Project Settings → API
SUPABASE_URL=https://qghtxzutmtyqpotokrnv.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# App secrets
SECRET_KEY=generate_a_long_random_string
JWT_SECRET_KEY=another_long_random_string
ENVIRONMENT=production

# Comma-separated origins allowed by CORS (include your Netlify site URL after deploy)
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,https://YOUR_APP.netlify.app
