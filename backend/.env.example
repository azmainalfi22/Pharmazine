# PostgreSQL — Supabase connection strings
#
# ⚠️  IMPORTANT — Use the Transaction pooler URL for cloud deployments (Render, Railway, etc.)
#     The direct host (db.*.supabase.co:5432) is IPv6-only in ap-southeast-1 and will fail
#     on cloud providers that only have IPv4.  The pooler (port 6543) is IPv4-compatible.
#
# Transaction pooler (✅ use this for Render / any cloud host):
DATABASE_URL=postgresql://postgres.qghtxzutmtyqpotokrnv:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require
#
# Direct connection (only for local dev if IPv6 is available):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.qghtxzutmtyqpotokrnv.supabase.co:5432/postgres?sslmode=require
#
# Notes:
# - Pooler username is postgres.PROJECT_REF (not plain “postgres”)
# - Replace YOUR_PASSWORD with your Supabase DB password (encode special chars: @ → %40, # → %23)
# - Copy the exact URI from Supabase dashboard → Project Settings → Database → “Transaction pooler”

# Supabase — Project Settings → API
SUPABASE_URL=https://qghtxzutmtyqpotokrnv.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# App secrets
SECRET_KEY=generate_a_long_random_string
JWT_SECRET_KEY=another_long_random_string
ENVIRONMENT=production

# Comma-separated origins allowed by CORS (include your Netlify site URL after deploy)
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,https://YOUR_APP.netlify.app
